Given a Singly Linked List of integers, delete all the alternate nodes in the list. Example: List: 10 -> 20 -> 30 -> 40 -> 50 -> 60 -> null Alternate nodes will be: 20, 40, and 60. Hence after deleting, the list will be: Output: 10 -> 30 -> 50 -> null
ANSWER
import java.io.*;
import java.util.*;
class Node
{
    int data;
    Node next;
    Node(int val)
    {
        data=val;
        next=null;
    }
}

public class Solution {

    public static void main(String[] args) {
        /* Enter your code here. Read input from STDIN. Print output to STDOUT. Your class should be named Solution. */
        Scanner sc= new Scanner(System.in);
        String []a=sc.nextLine().split(" ");
        int n=a.length;
        
        Node head=null,temp=null;
        for(int i=0;i<n;i++)
        {
            int value=Integer.valueOf(a[i]);
            Node nn= new Node(value);
            if(value==-1) break;
            if(head==null)
            {
                head=nn;
                temp=nn;
                
            }
            else{
               temp.next=nn;
               temp=nn;
               
                
            }}
            temp=head;
            while(temp!=null && temp.next!=null)
            {
                temp.next=temp.next.next;
                temp=temp.next;
            }
            Node tr=head;
            while(tr!=null)
            {
                System.out.print(tr.data+" ");
                tr=tr.next;
            }
    }
            
}
