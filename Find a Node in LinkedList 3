
Given a singly linked list of integers and an integer n, find and return the index for the first occurrence of 'n' in the linked list. -1 otherwise. Note : Assume that the Indexing for the linked list always starts from 0.
import java.io.*;
import java.util.*;
class Node
{
    int data;
    Node next;
    Node(int val)
    {
        data=val;
        next=null;
    }
}

public class Solution {

    public static void main(String[] args) {
        /* Enter your code here. Read input from STDIN. Print output to STDOUT. Your class should be named Solution. */
        Scanner sc= new Scanner(System.in);
        String []a=sc.nextLine().split(" ");
        int n=a.length;
        int s=sc.nextInt();
        Node head=null,temp=null;
        for(int i=0;i<n;i++)
        {
            int value=Integer.valueOf(a[i]);
            Node nn= new Node(value);
            if(value==-1) break;
            if(head==null)
            {
                head=nn;
                temp=nn;
                
            }
            else{
               temp.next=nn;
               temp=nn;
               
                
            }}
            int i=0;
            Node tr=head;
            while(tr!=null)
            {
                if(tr.data==s){
                System.out.print(i);
                return;
                }
                
                tr=tr.next;
                 i++;
            }
            System.out.print("-1");
        
    }
}
