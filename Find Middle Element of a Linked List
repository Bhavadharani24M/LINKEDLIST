        String []a=sc.nextLine().split(" ");
        int n=a.length;
        Node head=null,temp=null;
        for(int i=0;i<n;i++)
        {
            int value=Integer.valueOf(a[i]);
            Node nn= new Node(value);
            if(value==-1) break;
            if(head==null)
            {
                head=nn;
                temp=nn;
                
            }
            else{
               temp.next=nn;
               temp=nn;
               
                
            }}
            Node slow=head,fast=head;
            while(fast!=null && fast.next!=null)
            {
                slow=slow.next;
                fast=fast.next.next;
            }
            System.out.print(slow.data);
            
            
        
    }
}
